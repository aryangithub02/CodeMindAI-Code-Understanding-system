{
  "analysis": {
    "max_depth": 5,
    "max_file_size_kb": 500,
    "include_patterns": ["*.py", "*.js", "*.ts", "*.tsx", "*.jsx", "*.cs", "*.java", "*.go", "*.rs", "*.rb", "*.php", "*.swift", "*.kt"]
  },
  "security": {
    "enabled": true,
    "severity_threshold": "low"
  },
  "quality": {
    "enabled": true,
    "max_class_methods": 10,
    "max_function_lines": 80
  },
  "output": {
    "format": "markdown",
    "report_type": "full",
    "diagrams": true,
    "verbose": true
  }
}
